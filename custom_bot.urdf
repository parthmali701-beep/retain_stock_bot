<?xml version="1.0"?>
    <robot name="stock_bot">
        
        <link name="base_link">
            <visual>
                <geometry><box size="0.4 0.6 0.2"/></geometry>
                <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
            </visual>
            <collision>
                <geometry><box size="0.4 0.6 0.2"/></geometry>
            </collision>
            <inertial><mass value="20"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial>
        </link>

        <link name="mast">
            <visual>
                <geometry><box size="0.08 0.08 1.6"/></geometry>
                <origin xyz="0 0 0.8"/> 
                <material name="white"><color rgba="0.9 0.9 0.9 1"/></material>
            </visual>
            <collision>
                <geometry><box size="0.08 0.08 1.6"/></geometry>
                <origin xyz="0 0 0.8"/>
            </collision>
            <inertial><mass value="2"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial>
        </link>
        
        <joint name="mast_joint" type="fixed">
            <parent link="base_link"/>
            <child link="mast"/>
            <origin xyz="0 -0.2 0.1"/> 
        </joint>

        <link name="left_wheel">
            <visual>
                <geometry><cylinder radius="0.1" length="0.05"/></geometry>
                <origin xyz="0 0 0" rpy="1.5708 0 0"/> <material name="black"><color rgba="0 0 0 1"/></material>
            </visual>
            <collision>
                <geometry><cylinder radius="0.1" length="0.05"/></geometry>
                <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            </collision>
            <inertial><mass value="1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
        </link>

        <joint name="left_motor" type="continuous">
            <parent link="base_link"/>
            <child link="left_wheel"/>
            <origin xyz="-0.22 0 0"/> <axis xyz="1 0 0"/> </joint>

        <link name="right_wheel">
            <visual>
                <geometry><cylinder radius="0.1" length="0.05"/></geometry>
                <origin xyz="0 0 0" rpy="1.5708 0 0"/>
                <material name="black"><color rgba="0 0 0 1"/></material>
            </visual>
            <collision>
                <geometry><cylinder radius="0.1" length="0.05"/></geometry>
                <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            </collision>
            <inertial><mass value="1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
        </link>

        <joint name="right_motor" type="continuous">
            <parent link="base_link"/>
            <child link="right_wheel"/>
            <origin xyz="0.22 0 0"/> <axis xyz="1 0 0"/>
        </joint>

    </robot>
    