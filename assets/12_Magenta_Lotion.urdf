<?xml version="1.0"?>
<robot name="12_Magenta_Lotion">
  <material name="mat_body_12_Magenta_Lotion"><color rgba="0.8 0.0 0.4 1.0"/></material>
  <material name="mat_cap_12_Magenta_Lotion"><color rgba="0.1 0.1 0.1 1"/></material>
  <link name="baseLink">
    <inertial><mass value="0.15"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><origin xyz="0 0 0.075"/><geometry><cylinder radius="0.03" length="0.15"/></geometry><material name="mat_body_12_Magenta_Lotion"/></visual>
    <collision><origin xyz="0 0 0.075"/><geometry><cylinder radius="0.03" length="0.15"/></geometry></collision>
  </link>
  <link name="neck">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    <visual><origin xyz="0 0 0.175"/><geometry><cylinder radius="0.012" length="0.05"/></geometry><material name="mat_cap_12_Magenta_Lotion"/></visual>
    <collision><origin xyz="0 0 0.175"/><geometry><cylinder radius="0.012" length="0.05"/></geometry></collision>
  </link>
  <joint name="neck_joint" type="fixed"><parent link="baseLink"/><child link="neck"/><origin xyz="0 0 0"/></joint>
</robot>